# ============================================
# K-Content YouTube Shorts Automation
# .env 설정 파일
# ============================================
# 이 파일을 .env로 복사한 뒤 실제 키를 입력하세요:
#   cp .env.example .env
#
# ⚠️ .env 파일은 절대 git에 커밋하지 마세요!
# ============================================

# ── OpenAI API ──
# 대본(GPT-4o) + 음성(TTS) + 자막(Whisper) 모두 이 키 하나로 사용
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gemini API ──
# 썸네일 이미지 생성용
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── YouTube OAuth ──
# Google Cloud Console에서 다운받은 OAuth 클라이언트 JSON 경로
YOUTUBE_CLIENT_SECRET=credentials/youtube_oauth.json

# ── TTS 설정 ──
# 음성 선택: nova(여성/밝은톤), alloy(중성), echo(남성), shimmer(여성/차분)
TTS_VOICE=nova
TTS_MODEL=tts-1-hd

# ── 업로드 설정 ──
# private(비공개), unlisted(일부공개), public(공개)
UPLOAD_PRIVACY=private

# ── 일반 설정 ──
# true면 업로드 단계를 건너뜀
DRY_RUN=false
# 일일 최대 생성 영상 수
MAX_DAILY_VIDEOS=2
# 결과물 저장 경로
OUTPUT_DIR=output
