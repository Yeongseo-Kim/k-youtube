# Streamlit Cloud Secrets 설정 가이드
# 
# share.streamlit.io → 앱 선택 → Settings → Secrets 에 아래 내용 붙여넣기
# (실제 값으로 교체하세요)

# ── 로그인 정보 ──
AUTH_USERNAME = "admin"
AUTH_NAME = "Yeongseo"
AUTH_PASSWORD_HASH = "$2b$12$KL28nM/uZoBhjkgTjMq7uuvenTylq3yPf5SRBYwMsrvITJRxfrINi"  # 기본 비밀번호: admin123

# ── OpenAI ──
OPENAI_API_KEY = "sk-..."

# ── Gemini ──
GEMINI_API_KEY = "AIza..."

# ── Naver (사용 시) ──
NAVER_CLIENT_ID = ""
NAVER_CLIENT_SECRET = ""

# ── YouTube OAuth (refresh token 방식) ──
YOUTUBE_REFRESH_TOKEN = "여기에_refresh_token_값"
YOUTUBE_OAUTH_CLIENT_ID = "여기에_client_id_값"
YOUTUBE_OAUTH_CLIENT_SECRET = "여기에_client_secret_값"

# ── 업로드 설정 ──
UPLOAD_PRIVACY = "private"
